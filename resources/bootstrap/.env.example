# Proxmox Credentials
# Copy this file to .env and fill in your actual credentials
# Then run: source .env

export TF_VAR_proxmox_username="root@pam"
export TF_VAR_proxmox_password="your-password-here"
export TF_VAR_proxmox_api_token="root@pam!tofu=your-token-here"

# Hetzner Object Storage S3 Backend Credentials
export AWS_ACCESS_KEY_ID="your-hetzner-access-key"
export AWS_SECRET_ACCESS_KEY="your-hetzner-secret-key"
