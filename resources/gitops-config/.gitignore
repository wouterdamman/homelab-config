*.tfplan

# Terraform state directory
state/

# Sensitive input files (secrets)
input-files/*.yaml
input-files/*.yml
!input-files/*.example

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc
